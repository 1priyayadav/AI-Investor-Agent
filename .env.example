# ============================================================
# AI Investor Intelligence Agent — Environment Configuration
# ============================================================
# 1. Copy this file: copy .env.example .env  (Windows)
#                    cp .env.example .env    (Mac/Linux)
# 2. Fill in your values below
# 3. Restart the backend after changes
#
# NOTE: The system runs fully without any of the optional keys.
#       yfinance + ET Markets RSS work with ZERO configuration.
# ============================================================

# ------------------------------------------------------------
# 🔐 Security — REQUIRED (change this in production!)
# ------------------------------------------------------------
SECRET_KEY=supersecretkey_please_change_in_production

# ------------------------------------------------------------
# 📈 Alpha Vantage — OPTIONAL
# Get free key: https://www.alphavantage.co/support/#api-key
# Used for: Earnings data + insider trading data
# Without it: returns mock placeholder data (marked as demo)
# ------------------------------------------------------------
ALPHAVANTAGE_API_KEY=demo

# ------------------------------------------------------------
# 🗄️ Redis — OPTIONAL
# Used for: 10-minute API response cache, LangGraph state
# Without it: in-memory dict cache (data lost on restart)
# Run locally: docker run -p 6379:6379 redis
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# 🕸️ Neo4j Knowledge Graph — OPTIONAL
# Used for: Entity relationships (Director→Company, Investor→Company)
# Without it: graph queries return empty — system still works
# Free cloud: https://neo4j.com/cloud/platform/aura-graph-database/
# Run locally: docker run -p 7687:7687 -e NEO4J_AUTH=neo4j/testpassword neo4j
# ------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687

# ------------------------------------------------------------
# 🧠 ChromaDB Vector DB — OPTIONAL
# Used for: RAG retrieval from ET news + corporate filings
# Without it: falls back to fast in-memory keyword search
# Run locally: pip install chromadb && chroma run --port 8001
# ------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ------------------------------------------------------------
# 📰 ET Markets RSS — NO KEY NEEDED (public feed)
# Used for: Live ET Markets headlines for Opportunity Radar
# This works out of the box. Only change if you want a different feed.
# ------------------------------------------------------------
ET_MARKETS_RSS_URL=https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms
